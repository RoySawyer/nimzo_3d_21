#: main_21.cpp:2
msgid "Moves cannot be input to a video PGN file"
msgstr "Kustības nevar ievadīt video PGN failā"

#: main_21.cpp:4
msgid "unless the program is in puzzle mode,"
msgstr "ja vien programma nav mīklu režīmā,"

#: main_21.cpp:6
msgid "or the < Allow move entry > option"
msgstr "vai opciju < Atļaut pārvietošanas ierakstu >"

#: main_21.cpp:8
msgid "is checked in the media player options."
msgstr "ir atzīmēta multivides atskaņotāja opcijās."

#: main_21.cpp:10
msgid "Move entry message"
msgstr "Pārvietošanas ievades ziņojums"

#: main_21.cpp:12
msgid "Allow move entry"
msgstr "Atļaut pārvietošanas ievadi"

#: main_21.cpp:14 main_21.cpp:26
msgid "Allow move entry for a video PGN file"
msgstr "Atļaut video PGN faila pārvietošanas ierakstu"

#: main_21.cpp:16
msgid "Allow move entry  :  Check to allow the user to add moves to the game move list,"
msgstr "Atļaut gājienu ievadi: atzīmējiet, lai lietotājs varētu pievienot gājienus spēles gājienu sarakstam."

#: main_21.cpp:18
msgid "when the PGN file has been loaded with a media player video."
msgstr "kad PGN fails ir ielādēts ar multivides atskaņotāja video."

#: main_21.cpp:20
msgid "This means that the user can add sub-variations to the game."
msgstr "Tas nozīmē, ka lietotājs var pievienot spēlei apakšvariācijas."

#: main_21.cpp:22
msgid "If you are adding moves to the game, then the < Allow user input > option"
msgstr "Ja spēlei pievienojat gājienus, tad opcija < Atļaut lietotāja ievadi >"

#: main_21.cpp:24
msgid "must be checked in the Media player options dialog box."
msgstr "ir jāatzīmē multivides atskaņotāja opciju dialoglodziņā."
