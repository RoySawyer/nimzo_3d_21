#: main_21.cpp:2
msgid "Moves cannot be input to a video PGN file"
msgstr "Không thể nhập các động tác vào tệp video PGN."

#: main_21.cpp:4
msgid "unless the program is in puzzle mode,"
msgstr "trừ khi chương trình đang ở chế độ giải đố,"

#: main_21.cpp:6
msgid "or the < Allow move entry > option"
msgstr "hoặc tùy chọn < Cho phép nhập dữ liệu di chuyển >"

#: main_21.cpp:8
msgid "is checked in the media player options."
msgstr "tùy chọn này đã được chọn trong cài đặt trình phát đa phương tiện."

#: main_21.cpp:10
msgid "Move entry message"
msgstr "Di chuyển tin nhắn nhập"

#: main_21.cpp:12
msgid "Allow move entry"
msgstr "Cho phép nhập cảnh"

#: main_21.cpp:14 main_21.cpp:26
msgid "Allow move entry for a video PGN file"
msgstr "Cho phép di chuyển đối với tệp video PGN."

#: main_21.cpp:16
msgid "Allow move entry  :  Check to allow the user to add moves to the game move list,"
msgstr "Cho phép nhập nước đi: Chọn tùy chọn này để cho phép người dùng thêm nước đi vào danh sách nước đi của trò chơi."

#: main_21.cpp:18
msgid "when the PGN file has been loaded with a media player video."
msgstr "khi tệp PGN đã được tải bằng video trình phát đa phương tiện."

#: main_21.cpp:20
msgid "This means that the user can add sub-variations to the game."
msgstr "Điều này có nghĩa là người dùng có thể thêm các biến thể phụ vào trò chơi."

#: main_21.cpp:22
msgid "If you are adding moves to the game, then the < Allow user input > option"
msgstr "Nếu bạn đang thêm các nước đi vào trò chơi, thì hãy chọn tùy chọn < Cho phép người dùng nhập liệu >"

#: main_21.cpp:24
msgid "must be checked in the Media player options dialog box."
msgstr "Bạn phải chọn tùy chọn này trong hộp thoại Tùy chọn trình phát đa phương tiện."
