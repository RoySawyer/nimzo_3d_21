#: main_21.cpp:2
msgid "Moves cannot be input to a video PGN file"
msgstr "Lëvizjet nuk mund të futen në një skedar video PGN"

#: main_21.cpp:4
msgid "unless the program is in puzzle mode,"
msgstr "përveç nëse programi është në modalitetin e enigmës,"

#: main_21.cpp:6
msgid "or the < Allow move entry > option"
msgstr "ose opsioni <Lejo zhvendosjen e hyrjes>"

#: main_21.cpp:8
msgid "is checked in the media player options."
msgstr "është zgjedhur në opsionet e luajtësit të medias."

#: main_21.cpp:10
msgid "Move entry message"
msgstr "Zhvendos mesazhin e hyrjes"

#: main_21.cpp:12
msgid "Allow move entry"
msgstr "Lejo hyrjen e lëvizjes"

#: main_21.cpp:14 main_21.cpp:26
msgid "Allow move entry for a video PGN file"
msgstr "Lejo zhvendosjen e hyrjes për një skedar video PGN"

#: main_21.cpp:16
msgid "Allow move entry  :  Check to allow the user to add moves to the game move list,"
msgstr "Lejo hyrjen e lëvizjes: Kontrolloni për të lejuar përdoruesin të shtojë lëvizje në listën e lëvizjeve të lojës,"

#: main_21.cpp:18
msgid "when the PGN file has been loaded with a media player video."
msgstr "kur skedari PGN është ngarkuar me një video të media player-it."

#: main_21.cpp:20
msgid "This means that the user can add sub-variations to the game."
msgstr "Kjo do të thotë që përdoruesi mund të shtojë nën-variacione në lojë."

#: main_21.cpp:22
msgid "If you are adding moves to the game, then the < Allow user input > option"
msgstr "Nëse po shtoni lëvizje në lojë, atëherë opsioni <Lejo hyrjen e përdoruesit>"

#: main_21.cpp:24
msgid "must be checked in the Media player options dialog box."
msgstr "duhet të shënohet në kutinë e dialogut të opsioneve të luajtësit të medias."
