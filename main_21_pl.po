#: main_21.cpp:2
msgid "Moves cannot be input to a video PGN file"
msgstr "Ruchów nie można wprowadzać do pliku wideo PGN"

#: main_21.cpp:4
msgid "unless the program is in puzzle mode,"
msgstr "chyba że program jest w trybie układanki,"

#: main_21.cpp:6
msgid "or the < Allow move entry > option"
msgstr "lub opcja <Zezwalaj na wprowadzanie ruchu>"

#: main_21.cpp:8
msgid "is checked in the media player options."
msgstr "jest zaznaczone w opcjach odtwarzacza multimedialnego."

#: main_21.cpp:10
msgid "Move entry message"
msgstr "Wiadomość o wprowadzeniu ruchu"

#: main_21.cpp:12
msgid "Allow move entry"
msgstr "Zezwól na wejście do ruchu"

#: main_21.cpp:14 main_21.cpp:26
msgid "Allow move entry for a video PGN file"
msgstr "Zezwól na wprowadzanie danych dla pliku wideo PGN"

#: main_21.cpp:16
msgid "Allow move entry  :  Check to allow the user to add moves to the game move list,"
msgstr "Zezwalaj na wprowadzanie ruchów: Zaznacz, aby zezwolić użytkownikowi na dodawanie ruchów do listy ruchów w grze,"

#: main_21.cpp:18
msgid "when the PGN file has been loaded with a media player video."
msgstr "gdy plik PGN został załadowany za pomocą odtwarzacza multimedialnego wideo."

#: main_21.cpp:20
msgid "This means that the user can add sub-variations to the game."
msgstr "Oznacza to, że użytkownik może dodawać podwarianty do gry."

#: main_21.cpp:22
msgid "If you are adding moves to the game, then the < Allow user input > option"
msgstr "Jeśli dodajesz ruchy do gry, wybierz opcję <Zezwalaj na wprowadzanie danych przez użytkownika>"

#: main_21.cpp:24
msgid "must be checked in the Media player options dialog box."
msgstr "należy zaznaczyć w oknie dialogowym Opcje odtwarzacza multimedialnego."
