#: main_21.cpp:2
msgid "Moves cannot be input to a video PGN file"
msgstr "Gerakan tidak dapat dimasukkan ke dalam file PGN video."

#: main_21.cpp:4
msgid "unless the program is in puzzle mode,"
msgstr "kecuali jika program tersebut dalam mode teka-teki,"

#: main_21.cpp:6
msgid "or the < Allow move entry > option"
msgstr "atau opsi < Izinkan entri pemindahan >"

#: main_21.cpp:8
msgid "is checked in the media player options."
msgstr "dicentang di opsi pemutar media."

#: main_21.cpp:10
msgid "Move entry message"
msgstr "Pindahkan pesan entri"

#: main_21.cpp:12
msgid "Allow move entry"
msgstr "Izinkan masuk untuk memindahkan barang."

#: main_21.cpp:14 main_21.cpp:26
msgid "Allow move entry for a video PGN file"
msgstr "Izinkan pemindahan entri untuk file PGN video."

#: main_21.cpp:16
msgid "Allow move entry  :  Check to allow the user to add moves to the game move list,"
msgstr "Izinkan entri langkah: Centang untuk mengizinkan pengguna menambahkan langkah ke daftar langkah permainan."

#: main_21.cpp:18
msgid "when the PGN file has been loaded with a media player video."
msgstr "ketika file PGN telah dimuat dengan video pemutar media."

#: main_21.cpp:20
msgid "This means that the user can add sub-variations to the game."
msgstr "Ini berarti pengguna dapat menambahkan sub-variasi ke dalam permainan."

#: main_21.cpp:22
msgid "If you are adding moves to the game, then the < Allow user input > option"
msgstr "Jika Anda menambahkan langkah ke dalam permainan, maka pilih opsi < Izinkan input pengguna >."

#: main_21.cpp:24
msgid "must be checked in the Media player options dialog box."
msgstr "Harus dicentang di kotak dialog Opsi pemutar media."
