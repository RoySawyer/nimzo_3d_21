#: main_21.cpp:2
msgid "Moves cannot be input to a video PGN file"
msgstr "No se pueden introducir movimientos en un archivo PGN de ​​vídeo."

#: main_21.cpp:4
msgid "unless the program is in puzzle mode,"
msgstr "a menos que el programa esté en modo rompecabezas,"

#: main_21.cpp:6
msgid "or the < Allow move entry > option"
msgstr "o la opción < Permitir entrada de movimiento >"

#: main_21.cpp:8
msgid "is checked in the media player options."
msgstr "Está marcada en las opciones del reproductor multimedia."

#: main_21.cpp:10
msgid "Move entry message"
msgstr "Mover mensaje de entrada"

#: main_21.cpp:12
msgid "Allow move entry"
msgstr "Permitir entrada de movimiento"

#: main_21.cpp:14 main_21.cpp:26
msgid "Allow move entry for a video PGN file"
msgstr "Permitir la entrada de movimiento para un archivo PGN de ​​vídeo"

#: main_21.cpp:16
msgid "Allow move entry  :  Check to allow the user to add moves to the game move list,"
msgstr "Permitir la entrada de movimientos: Marque esta casilla para permitir que el usuario agregue movimientos a la lista de movimientos del juego."

#: main_21.cpp:18
msgid "when the PGN file has been loaded with a media player video."
msgstr "cuando el archivo PGN se ha cargado con un vídeo de un reproductor multimedia."

#: main_21.cpp:20
msgid "This means that the user can add sub-variations to the game."
msgstr "Esto significa que el usuario puede añadir subvariantes al juego."

#: main_21.cpp:22
msgid "If you are adding moves to the game, then the < Allow user input > option"
msgstr "Si estás añadiendo movimientos al juego, entonces la opción < Permitir entrada del usuario >"

#: main_21.cpp:24
msgid "must be checked in the Media player options dialog box."
msgstr "Debe estar marcada en el cuadro de diálogo de opciones del reproductor multimedia."
