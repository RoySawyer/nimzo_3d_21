#: main_21.cpp:2
msgid "Moves cannot be input to a video PGN file"
msgstr "Não é possível inserir movimentos em um arquivo PGN de ​​vídeo."

#: main_21.cpp:4
msgid "unless the program is in puzzle mode,"
msgstr "a menos que o programa esteja no modo de quebra-cabeça,"

#: main_21.cpp:6
msgid "or the < Allow move entry > option"
msgstr "ou a opção < Permitir entrada de movimento >"

#: main_21.cpp:8
msgid "is checked in the media player options."
msgstr "está marcado nas opções do reprodutor de mídia."

#: main_21.cpp:10
msgid "Move entry message"
msgstr "Mensagem de entrada Mover"

#: main_21.cpp:12
msgid "Allow move entry"
msgstr "Permitir entrada de movimento"

#: main_21.cpp:14 main_21.cpp:26
msgid "Allow move entry for a video PGN file"
msgstr "Permitir entrada de movimento para um arquivo de vídeo PGN"

#: main_21.cpp:16
msgid "Allow move entry  :  Check to allow the user to add moves to the game move list,"
msgstr "Permitir entrada de jogadas: Marque esta opção para permitir que o usuário adicione jogadas à lista de jogadas do jogo."

#: main_21.cpp:18
msgid "when the PGN file has been loaded with a media player video."
msgstr "quando o arquivo PGN for carregado com um vídeo de um reprodutor de mídia."

#: main_21.cpp:20
msgid "This means that the user can add sub-variations to the game."
msgstr "Isso significa que o usuário pode adicionar subvariações ao jogo."

#: main_21.cpp:22
msgid "If you are adding moves to the game, then the < Allow user input > option"
msgstr "Se você estiver adicionando jogadas ao jogo, selecione a opção < Permitir entrada do usuário >."

#: main_21.cpp:24
msgid "must be checked in the Media player options dialog box."
msgstr "Deve estar marcado na caixa de diálogo Opções do reprodutor de mídia."
